#  which variables exist.
# ============================================================================

# A long, random string in real environments (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-string

AUTH_DB_PASSWORD=change-me
PRODUCTS_DB_PASSWORD=change-me
ORDERS_DB_PASSWORD=change-me
